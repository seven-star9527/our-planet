generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model ChatMessage {
  id        Int                    @id @default(autoincrement())
  sender    String
  content   String
  sendTime  DateTime
  embedding Unsupported("vector")?

  @@map("chat_messages")
}

model Moment {
  id          Int          @id @default(autoincrement())
  author      String
  content     String
  images      String[]
  tags        String[]
  createdAt   DateTime     @default(now())
  videoUrl    String?
  bucketLists BucketList[]
  comments    Comment[]
  likes       Like[]

  @@map("moments")
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  author    String
  momentId  Int
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id])

  @@map("comments")
}

model Like {
  id        Int      @id @default(autoincrement())
  author    String
  emoji     String
  momentId  Int
  createdAt DateTime @default(now())
  moment    Moment   @relation(fields: [momentId], references: [id])

  @@map("likes")
}

model Milestone {
  id                   Int      @id @default(autoincrement())
  title                String
  isCountdown          Boolean  @default(false)
  date                 DateTime
  remind               Boolean  @default(false)
  anniversaryName      String?
  isAnniversary        Boolean  @default(false)
  isDefaultAnniversary Boolean  @default(false)

  @@map("milestones")
}

model BucketList {
  id         Int       @id @default(autoincrement())
  title      String
  status     String    @default("TODO")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  momentId   Int?
  targetDate DateTime?
  moment     Moment?   @relation(fields: [momentId], references: [id])

  @@map("bucket_lists")
}

model AppSetting {
  id          Int      @id @default(autoincrement())
  key         String
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("app_settings")
}

model ThemeSetting {
  id              Int      @id @default(autoincrement())
  name            String
  primaryColor    String
  secondaryColor  String
  backgroundColor String
  isActive        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("theme_settings")
}

// 足迹地图模型
model Footprint {
  id        Int      @id @default(autoincrement())
  city      String   // 城市名，如"上海", "东京"
  location  String?  // 具体地点，如"迪士尼乐园"
  date      DateTime? // 打卡时间
  notes     String?  // 简短备注
  latitude  Float?   // 纬度 (可选，以后如果用真实地图组件会用到)
  longitude Float?   // 经度 (可选)
  createdAt DateTime @default(now())

  @@map("footprints")
}

// 生理期记录
model PeriodRecord {
  id        Int      @id @default(autoincrement())
  startDate DateTime // 姨妈开始的日期
  endDate   DateTime? // 结束日期 (可选)
  cycle     Int      @default(28) // 周期长度，默认28天
  notes     String?  // 备注
  createdAt DateTime @default(now())

  @@map("period_records")
}

// npx prisma db push

// 好感度与亲密度
model AffinityScore {
  id           Int      @id @default(autoincrement())
  fromRole     String   // "boy" 或 "girl"
  toRole       String   // "boy" 或 "girl"
  favorability Int      @default(50) // 好感度 0-100
  intimacy     Int      @default(50) // 亲密度 0-100
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([fromRole, toRole])
  @@map("affinity_scores")
}

model AffinityLog {
  id        Int      @id @default(autoincrement())
  fromRole  String   // 操作者
  toRole    String   // 被操作者
  type      String   // "favorability" 或 "intimacy"
  delta     Int      // 变化量，如 +5 或 -3
  reason    String   // 事由
  createdAt DateTime @default(now())

  @@map("affinity_logs")
}